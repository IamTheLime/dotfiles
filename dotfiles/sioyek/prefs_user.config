# Sioyek preferences
# Docs: https://sioyek-documentation.readthedocs.io/en/latest/configuration.html

# ---------- DARK MODE ----------
# Start in dark mode by default (toggle with F8)
startup_commands             toggle_dark_mode

# Dim whites slightly to reduce eye strain in dark mode (0.0 = fully dimmed, 1.0 = full white)
dark_mode_contrast           0.8

# Background color shown outside PDF pages in dark mode
dark_mode_background_color   0.0 0.0 0.0

# ---------- APPEARANCE ----------
# App background color (shown outside PDF page bounds in light mode)
background_color             0.15 0.15 0.15

# Use modern keybind parsing (avoids issues with some keyboard layouts)
use_legacy_keybinds          0

# Show long menu items in multiple lines rather than truncating
multiline_menus              1

# Ruler mode: highlight a rectangle around the current line in visual mark mode
ruler_mode                   1
ruler_padding                1.0
ruler_x_padding              5.0

# ---------- SCROLL / ZOOM ----------
# Fraction of screen moved on screen_down / screen_up
move_screen_ratio            0.5

# Zoom step factor
zoom_inc_factor              1.2

# Zoom toward mouse cursor instead of screen center
wheel_zoom_on_cursor         1

# Touchpad sensitivity
touchpad_sensitivity         1.0

# ---------- SEARCH ----------
# Fast indexed search
super_fast_search            1

# Case-insensitive search by default
case_sensitive_search        0

# Search engines (access via external_search command, then press the letter)
search_url_g                 https://www.google.com/search?q=
search_url_s                 https://scholar.google.com/scholar?q=
search_url_l                 http://gen.lib.rus.ec/scimag/?q=

# Middle-click search engine (g = google)
middle_click_search_engine         g
shift_middle_click_search_engine   s

# ---------- TABLE OF CONTENTS ----------
flat_toc                     0
collapsed_toc                0

# Auto-generate TOC if document doesn't have one
create_table_of_contents_if_not_exists 1
max_created_toc_size         5000

# ---------- BOOKMARKS ----------
sort_bookmarks_by_location   1

# ---------- MISC ----------
# Do not check for updates on startup
check_for_updates_on_startup 0

# Show full path in recent documents list
show_doc_path                0

# Pre-render the next page in presentation mode (reduces flickering)
prerender_next_page_presentation 1

# Re-render overview at correct resolution (better quality, slightly more CPU)
rerender_overview            1

# Show document name in status bar
show_document_name_in_statusbar 1

# ---------- HIGHLIGHT COLORS ----------
#Amethyst
highlight_color_a 0.94 0.64 1.00
#Blue
highlight_color_b 0.00 0.46 0.86
#Caramel
highlight_color_c 0.60 0.25 0.00
#Green
highlight_color_g 0.17 0.81 0.28
#Honeydew
highlight_color_h 1.00 0.80 0.60
#Jade
highlight_color_j 0.58 1.00 0.71
#Orpiment
highlight_color_o 1.00 0.64 0.02
#Pink
highlight_color_p 1.00 0.66 0.73
#Red
highlight_color_r 1.00 0.00 0.06
#Sky
highlight_color_s 0.37 0.95 0.95
#Turquoise
highlight_color_t 0.00 0.60 0.56
#Yellow
highlight_color_y 1.00 1.00 0.00
