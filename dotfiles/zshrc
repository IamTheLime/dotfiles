# My Custom command completions


export REPOS_DIR="${HOME}/Documents/repos"
zstyle ':fzf-tab:complete:repos:*' fzf-preview 'bat --color=always "${REPOS_DIR}/$word/README.md" 2>/dev/null || echo "No README found"'
repos() {
   cd "${REPOS_DIR}/$1"
}
_repos() {
  local -a entries
  local repo_dir wt_dir
  for repo_dir in "${REPOS_DIR}"/*/; do
    [[ -d "$repo_dir" ]] || continue
    local repo=$(basename "$repo_dir")
    local -a subdirs=()
    for wt_dir in "${repo_dir}"*/; do
      [[ -d "$wt_dir" ]] && subdirs+=("$wt_dir")
    done
    if (( ${#subdirs[@]} > 0 )); then
      for wt_dir in "${subdirs[@]}"; do
        entries+=("${repo}/$(basename "$wt_dir")")
      done
    else
      entries+=("$repo")
    fi
  done
  compadd -a entries
}
compdef _repos repos

gitclonewithtree() {
  local url="$1"
  local repo_name=$(basename "$url" .git)
  mkdir -p "${REPOS_DIR}/${repo_name}"
  git clone "$url" "${REPOS_DIR}/${repo_name}/main"
  echo "Cloned into ${REPOS_DIR}/${repo_name}/main"
  echo "Add worktrees with: git -C ${REPOS_DIR}/${repo_name}/main worktree add ../<branch-name> <branch>"
}

export PERSONAL_REPO_FOLDER="${HOME}/repos"
zstyle ':fzf-tab:complete:prep:*' fzf-preview 'bat --color=always ${PERSONAL_REPO_FOLDER}/$realpath/README.md'
prep() {
    cd "${PERSONAL_REPO_FOLDER}/$1"
}
_prep() {
   # this is one way of defining completion by directory, where 
   ((CURRENT == 2)) && _files -/ -W ${PERSONAL_REPO_FOLDER}
}
compdef _prep prep

